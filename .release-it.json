{
  "plugins": {
    "release-it-pnpm": {
      "publishCommand": "echo 'skipping publish'"
    }
  },
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}"
  },
  "hooks": {
    "before:init": [
      "pnpm run lint",
      "pnpm run typecheck",
      "pnpm run test",
      "pnpm run knip"
    ],
    "after:bump": [
      "pnpm run build",
      "pnpm run validate-safari"
    ]
  }
}
